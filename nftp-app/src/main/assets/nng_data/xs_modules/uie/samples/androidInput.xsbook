        "import {readText, writeText, hasText, getPrimaryClipDescription} from \"android://clipboard\"",
        "{}",
        "//$log(clipboard);",
        "$log(await hasText());",
        "$log(string(await readText()));",
        "const desc = await getPrimaryClipDescription();",
        "desc.hasMimeType(\"text/plain\"), desc.getMimeTypeCount(), desc.getMimeType(0)",
        ""
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {readText, writeText, hasText, getPrimaryClipDescription, onClipboardChanged} from \"android://clipboard\"",
        "{}",
        "const onT=onClipboardChanged(async (has)=>console.log(\"cb text\", has, await readText()));",
        "await Chrono.delay(1min, $cancellation)"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "uie/android/clipboard.xs provides real subscription<br>",
        "Unfortunatelly it is not straightforward to make an optional forwarding module. TODO"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {clipboardChanged, hasText, readText} from \"uie/android/clipboard.xs\"",
        "{}",
        "const onT = clipboardChanged.subscribe(async (has)=>console.log(\"cb text\", has, await readText()));",
        "await Chrono.delay(1min, $cancellation)"
      ]
    },
