      "source": [
        "Copy a file (e.g xs-unstripped)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import * as fs from \"system://fs\"",
        "import {Uint8Array, DataReader, DataWriter} from \"system://core.types\"",
        "const fname = \"uie.exe\";",
        "{}",
        "let inp = ??fs.openSync(fname);",
        "if (!inp) {",
        "    $log(inp);",
        "    return;",
        "}",
        "let f = ??fs.openSync(`copy_out`,{write: true, truncate: true} );",
        "if (!f) {",
        "    $log(f);",
        "    return;",
        "}",
        "let b = Uint8Array(16*1024);",
        "let sum = 0;",
        "while(true) {",
        "    const n = ?? inp.readSync(b);",
        "    if (!n)",
        "        break;",
        "    f.writeSync(b.subarray(0,n));",
        "    sum += n;",
        "}",
        "f.close();",
        "inp.close();",
        "$log(`wrote ${sum} bytes`);"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import * as fs from \"system://fs\"",
        "import {Uint8Array, DataReader, DataWriter} from \"system://core.types\"",
        "const fname = \"xs\";",
        "{}",
        "let inp = ??fs.openSync(fname);",
        "if (!inp) {",
        "    $log(inp);",
        "    return;",
        "}",
        "let bs = [{b: Uint8Array(16*1024), w:undef}, {b:Uint8Array(16*1024), w:undef}];",
        "let sum = 0;",
        "let first = true;",
        "let idx=0;",
        "while(true) {",
        "    let b = bs[idx].b;",
        "    if (bs[idx].w)",
        "        await bs[idx].w;",
        "    const n = ?? inp.readSync(b);",
        "    if (!n)",
        "        break;",
        "    bs[idx].w = fs.writeFile(\"copy_out2\", b.subarray(0,n), first ? undef : {append:true});",
        "    if (++idx >= bs.length)",
        "        idx = 0;",
        "    first = false;",
        "    sum += n;",
        "}",
        "inp.close();",
        "$log(`wrote ${sum} bytes`);"
      ]
    },
