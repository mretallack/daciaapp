        "$log(\"join\");",
        "$log(\"\\n\".join(dirFiles(\"c:/work/\")));//.map(_=>`${_}\\n---x---`));",
        "$log(\"tuple\");",
        "$log(dirFiles(\"c:/work/\").toTuple());",
        "$log(\"totuple joined\");",
        "$log(dirFiles(\"c:/work/\").toTuple().join(\" \"));",
        "...dirFiles(\"c:/work/\");",
        ""
      ]
    },
