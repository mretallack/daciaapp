      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import * as objc from \"system://objc\"",
        "{}",
        "//$log(objc.dumpMethods( objc.getClass('NSBlock')));",
        "$log(objc.dumpMethods( objc.class.__NSMallocBlock__, 1));"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import * as objc from \"system://objc\"",
        "const NSArray = objc.class.NSArray;",
        "{}",
        "NSArray arr [ 10, 20, 30];",
        "arr.enumerateObjectsUsingBlock(objc.makeBlock(\"v@@Q^B\", (obj,idx, stop) => {",
        "    stop.value = true;",
        "    $log(obj,idx,stop.value);",
        "}));",
        "//const d = {a:5, b:6, c:42};objc.toObj(d).c=2;",
        ""
      ]
    },
