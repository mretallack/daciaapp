        "import {connect} from \"system://socket\"",
        "import {Uint8Array} from \"system://core.types\"",
        "import {lineReader} from \"core/ioUtils.xs\"",
        "{}",
        "const s = ?? await connect({path:\"alma\"} /*\"localhost:56789\"*/);",
        "if (!s) { $log(\"failed to connect\",s); return}",
        "$log(\"Connected\");",
        "s.write(\"EXIT\\n\");",
        "const b = Uint8Array(100);",
        "let res = ?? await.race([s.read(b), Chrono.delay(1s)]);",
        "if (res && res >0) $log(\"resp: \", b.substring(0, res))",
        ""
      ]
