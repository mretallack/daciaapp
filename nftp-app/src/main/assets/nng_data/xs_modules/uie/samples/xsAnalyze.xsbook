    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "isSuiteIncluded(suiteDict, include) {",
        "    for (let incTag in include) {",
        "        if (??incTag.regexp) {",
        "            let nameFilter = incTag.regexp.toLowerCase();",
        "            let suiteName = string(suiteDict.id).toLowerCase();",
        "            if (suiteName.indexOf(nameFilter)>=0) ",
        "                return true;",
        "            for (let case in suiteDict.cases) {",
        "                let caseName = string(case.name).toLowerCase();",
        "                if (caseName.indexOf(nameFilter)>=0)",
        "                    return true;",
        "            }",
        "        } else if (let m = incTag?.metadata) {",
        "            if (isSuiteMeta(m, suiteDict.suite.metadata)) return true;",
        "        } else {",
        "            for (let caseTags in Util.values(suiteDict.suite.caseTags)) {",
        "                if (isTagIncluded(incTag, caseTags)) return true;",
        "            }",
        "            if (isSuiteTag(incTag, suiteDict.suite.tags)) return true;",
        "        }",
        "    }",
        "    return false;",
        "}",
        "{}",
        "Analyzer a;",
        "analyze(isSuiteIncluded, a);"
      ]
    },
