      "source": [
        "retrieveIds(dataDict) {",
        "    var idOrderedList = [];",
        "    for(var names in Util.keys(dataDict)) {",
        "        var nameList = string(names).split(',');",
        "        var idList = [];",
        "        for(var name in nameList) {",
        "            var ids = ??ContentIdMapper.getIdsByAlias(name);",
        "            for(var id in ids) {",
        "                if(id == undef)",
        "                    idList.append(name);",
        "                else",
        "                    idList.append(id);",
        "            }",
        "        }",
        "        idOrderedList.append({key: string(names), ids: idList.join(',').toLowerCase()});",
        "    }",
        "    idOrderedList.sort((lhs, rhs) => { return lhs.ids <=> rhs.ids; });",
        "    return idOrderedList;",
        "}",
        "assembleData(instances, dataDict) {",
        "    var dataList = [];",
        "    var idOrderedList = [];",
        "    for(var names in Util.keys(dataDict)) {",
        "        var nameList = string(names).split(',');",
        "        var idList = [];",
        "        for(var name in nameList) {",
        "            var ids = ??ContentIdMapper.getIdsByAlias(name);",
        "            for(var id in ids)",
        "            {",
        "                if(id == undef)",
        "                    idList.append(name);",
        "                else",
        "                    idList.append(id);",
        "            }",
        "        }",
        "",
        "        idOrderedList.append({key: string(names), ids: idList.join(',').toLowerCase()});",
        "    }",
        "",
        "    idOrderedList.sort((lhs, rhs) => { return lhs.ids <=> rhs.ids; });",
        "",
        "    for(var idData in idOrderedList) {",
        "        var data = dataDict[idData.key];",
        "        var idList = idData.ids.split(\",\");",
        "        if(ContentIdChecker.currentContentHasContentIds(instances, true, idList)) {",
        "            for(var entry in data) {",
        "                var idx;",
        "                if(entry?.data)",
        "                {",
        "                    if(entry.data[1]==@DELETED_TESTCASE)",
        "                        continue;",
        "                    idx = dataList.findIndex(x => x[0] == entry.data[0]);",
        "                }",
        "                else",
        "                {",
        "                    if(entry[1]==@DELETED_TESTCASE)",
        "                        continue;",
        "                    idx = dataList.findIndex(x => x[0] == entry[0]);",
        "                }",
        "                if(idx >= 0)",
        "                    dataList[idx] = entry?.data ? entry.data : entry;",
        "                else",
        "                    dataList.append(entry?.data ? entry.data : entry);",
        "            }",
        "        }",
        "    }",
        "    if(len(dataList) == 0)",
        "        return failure({message: \"No data selected for ddtest!\"});",
        "    return dataList;",
        "}",
        "getExistingItem( item ){",
        "    var match;",
        "    if ( item ) {",
        "        let historyId = generateHistoryIdFrom( item.id );",
        "        for ( var storageItem in this.storage.itemList ){",
        "            if ( ??storageItem.id && ??historyId && ( storageItem.id == historyId ) ) {",
        "                match = storageItem;",
        "                break;",
        "            }",
        "        }",
        "    }",
        "    return match;",
        "}",
        "{}",
        "analyze(getExistingItem, a);"
      ]
    },
