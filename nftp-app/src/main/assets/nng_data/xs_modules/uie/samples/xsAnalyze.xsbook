        "test_3(i) {",
        "    if (let m = i?.metadata) {",
        "            if (isSuiteMeta(m, suiteDict.suite.metadata)) return true;",
        "    } else {",
        "        m",
        "    }",
        "}",
        "run() {  runAsyncGenerator(this.runGen(), error_handler.raise(\"async failure while running test\", ?)); }",
        "_checker(exp) {",
        "    if (!exp.cardinality) {",
        "        var es = new Util.ErrorStream;",
        "        return;",
        "    }",
        "    for (var ptr in exp._sequences) {",
        "        if (ptr.sequence == this) {",
        "            this._checker(ptr.prevExpectation);",
        "            return;",
        "        }",
        "    }",
        "}",
        "make_crc_table(crc_table) {",
        "    var c;",
        "    var n, k;",
        "    for (n = 0; n < 256; n++) {",
        "        c = n;",
        "        for (k = 0; k < 8; k++) {",
        "            if (Math.and(c, 1))",
        "                c = Math.xor(0xedb88320, Math.shr(c,1));",
        "            else",
        "                c = Math.shr(c, 1);",
        "        }",
        "        crc_table[n] = c;",
        "    }",
        "    return crc_table;",
        "}",
        "{}",
        "analyze(make_crc_table,a);"
      ]
