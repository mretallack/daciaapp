        "        var value = [];",
        "        var names = {};",
        "        if(displays == @all) {",
        "            for (var win in TestWindowManager.getAllWindows()) {",
        "                value.push(win.displayId);",
        "                names[win.displayId] = win.tag;",
        "            }",
        "        } else {",
        "            // it's an arraylike object if it has the property named `0`",
        "            var disp = typeof(displays) == @object && hasProp(displays, 0) ? displays : [displays];",
        "            for (var d in disp) {",
        "                if (typeof(d) == @object && hasProp(d, @displayId)) {",
        "                    value.push(d.displayId);",
        "                    names[d.displayId] = d.tag;",
        "                } else {",
        "                    value.push(d);",
        "                    // empty names",
        "                }",
        "",
        "            }",
        "        }",
        "        ",
        "        this.options.displays = value;",
        "        this.options.displayNames = names;",
        "    }",
        "{}",
        "Analyzer a;",
        "analyze(processDisplays, a);"
      ]
