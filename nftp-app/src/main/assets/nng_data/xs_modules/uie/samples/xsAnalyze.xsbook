        "    if (exp == undef)",
        "        return;",
        "",
        "    if (!exp.cardinality.isSatisfied(exp._numCalls())) {",
        "        var es = new Util.ErrorStream;",
        "        es.add(\"Sequence defined in '\").add(this._defId).add(\"' not completed.\").add(\"\\n\").addSrcInfo(this._defLoc);",
        "        emitError(es);",
        "        return;",
        "    }",
        "",
        "    for (var ptr in exp._sequences) {",
        "        if (ptr.sequence == this) {",
        "            this._checker(ptr.prevExpectation);",
        "            return;",
        "        }",
        "    }",
        "}",
        "{}",
        "Analyzer a;",
        "analyze(_checker, a);"
      ]
