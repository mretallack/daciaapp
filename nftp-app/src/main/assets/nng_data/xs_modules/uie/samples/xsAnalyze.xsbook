      "source": [
        "export hideAllLayersButNot( visibleLayers, mapRenderer ) {",
        "\tfor( let layer in mapRenderer.mapLayers ) {",
        "\t\tlayer.visible = 0;",
        "\t\tfor( let visibleLayerId in visibleLayers ) {",
        "\t\t\tif( visibleLayerId == layer.id ) {",
        "\t\t\t\tlayer.visible = 1;",
        "\t\t\t\tbreak;",
        "\t\t\t}",
        "\t\t}",
        "\t}",
        "}",
        "refreshLayerVisibility( layerType ) {",
        "    let layersToSet; ",
        "    if ( layerType ) ",
        "        layersToSet = [ layerType ];",
        "    else ",
        "        layersToSet = keys( this.visibleLayers );",
        "    let layers = this.mapRenderer.mapLayers;",
        "    for ( let key in layersToSet)",
        "    {",
        "        let filter = this.visibleLayers[ key ].filter;",
        "        let filtered = from(layers).filter( filter ).build();",
        "        for (let item in filtered) {",
        "            item.visible = this.settings[ this.visibleLayers[ key ].context ]; ",
        "        }",
        "    }",
        "}",
        "loopInLoop(arg) {",
        "    for(let k in arg) {",
        "        let x = k.x;",
        "        let y = k.y;",
        "        for(let a in x) {",
        "            do_(a);",
        "        }",
        "        for(let b in y) {",
        "            do_(b);",
        "        }",
        "    }",
        "}",
        "processClosed(status) {",
        "    if (!this.exiting)",
        "        FAIL(`${this.name} exited with ${status}`);",
        "    let respawn = this.respawnHook;",
        "    this.respawnHook = undef; // priv #respawnHook",
        "    respawn?.();",
        "}",
        "s8_opt_ch() {",
        "    a < b < c?d:e;",
        "    a?.b?.c?.(1,2)?.[3](4);",
        "}",
        "createRegexpList(filter) {",
        "    if (filter == undef) return [];",
        "    let regexpList = [];",
        "    if (hasProp(filter, Symbol.iterator)) {",
        "        for (let f in filter) {",
        "            if (??f.regexp) {",
        "                regexpList.append(new re.Regexp(\".*\"+f.regexp+\".*\", \"i\"));",
        "            }",
        "        }",
        "    } else {",
        "        if (??filter.regexp) {",
        "            regexpList.append(new re.Regexp(\".*\"+filter.regexp+\".*\", \"i\"));",
        "        }",
        "    }",
        "",
        "    return regexpList;",
        "}",
        "isTagIncluded(includeTag, tags) {",
        "    //Iter.seq(tags).any(string.eq(includeTag, ?));",
        "    if (isIterable(tags)) {",
        "        for (let t in tags) {",
        "            if (string.eq(t, includeTag))",
        "                return true;",
        "        }",
        "    } else {",
        "        if (string.eq(tags, includeTag))",
        "            return true;",
        "    }",
        "    return false;",
        "}",
        "{}",
        "analyze(createRegexpList, a);",
        "//analyze(loopInLoop, a);",
        "//analyze(hideAllLayersButNot, a);",
        "//analyze(refreshLayerVisibility,a);",
        "//analyze(processClosed,a);",
        "//analyze(s8_opt_ch,a);"
      ]
