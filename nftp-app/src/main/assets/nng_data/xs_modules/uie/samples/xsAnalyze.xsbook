    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "class TestRunner {",
        "    #listener;",
        "    #currentTestCase = undef;",
        "    #currentSuite;",
        "    #testRunHasBeenCanceled = false;",
        "    #settings;",
        "    #errorHandler; ",
        "    #testData; //",
        "    #createSuiteInstance;",
        "    #shuffle;",
        "",
        "    *tests(testQuery) {",
        "        let caseRegexpList = createRegexpList(testQuery.case ?? undef);",
        "        let suiteRegexpList = createRegexpList(testQuery.suite ?? undef);",
        "",
        "        let suites = filterSuites(AllTests, testQuery, suiteRegexpList);",
        "        let randomWhat = testQuery?.randomize?.what;",
        "        let randomSeed = testQuery?.randomize?.seed;",
        "        if (string.eq(randomWhat, \"suites\") || string.eq(randomWhat, \"all\")) {",
        "            suites = this.#shuffle(suites, randomSeed);",
        "        }",
        "",
        "        const exclude = excludeQuery(testQuery);",
        "",
        "        for (let suite in suites) {",
        "            let allCases = filterCases(suite.cases, testQuery, caseRegexpList);",
        "            // multiple run calls may be made, so we should handle cleanup here as well (similar to done)",
        "            let currSuite = this.#createSuiteInstance(suite); // suite is in suiteDict format {id, suite, cases}, returns TestSuiteInstance",
        "            ",
        "            if (string.eq(randomWhat,  \"tests\") || string.eq(randomWhat,\"all\")) {",
        "                allCases = this.#shuffle(allCases, randomSeed);",
        "            }",
        "            for (let case in allCases) {",
        "                if (this.#testRunHasBeenCanceled) {",
        "                    yield @cancelled;",
        "                    return;",
        "                }",
        "                const testCaseInstanceImpl = exclude && exclude(case) ? SkippedTestCaseInstance",
        "                                              : TestCaseInstance;",
        "",
        "                this.#currentTestCase = new testCaseInstanceImpl(this, currSuite, case);",
        "                yield this.#currentTestCase;",
        "            }",
        "        }",
        "        this.#currentTestCase = undef;",
        "    }",
        "}",
        "{}",
        "Analyzer a;",
        "analyze(TestRunner.prototype.tests, a);"
      ]
    },
