    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {prop, propOr} from \"system://functional\"",
        "const test = {alma:\"al1\", korte:\"ko2\", banan: \"ba3\"};",
        "{}",
        "$log(prop(@alma,test));",
        "$log(prop(@alma)(test));",
        "$log(propOr(-1, @_noprop, test));",
        "const propOpt = propOr(undef);",
        "propOpt(@alma)(test);",
        "$log(propOr(-1)(@_noprop)(test));",
        "/*class HereExtractor {",
        "    //static name(o) { o.fancyName}",
        "    static name = prop(@fancyName)",
        "}",
        "extractor = HereExtractor;",
        "extractor.name(item);*/"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {prop, propOr, path,assocPath} from \"system://functional\"",
        "const path_abc = path(@a, @b, @c);",
        "const o1 = #{a: #{b: #{c: 42}}};",
        "const o2 = #{a:[ #{c: 100}, #{c:1000}]};",
        "const o3 = #{a:[ #{c: 10}, #{c:42}]};",
        "{}",
        "$log(path_abc(o1)); //pipe(path(\"a.b\"), prop(\"mapkey\"));",
        "$log(path(\"a.b.c\")(o1));",
        "const a1c = path(\"a[1].c\");",
        "$log(a1c(o2), a1c(o3));",
        "$log(??a1c(o1));",
        "$log(path(\"a[0]\")(o2));",
        "$log(path(\"byteLength\")(\"aaa\")); // 3",
        "$log(path(\"a.b.c\", o1));",
        "$log(\"assocPath a.b.c\", assocPath(\"a.b.c\", -42, o1));",
        "$log(assocPath(\"a.b.c\", -42, #{a:#{b:undef}}));",
        "$log(assocPath(\"a.b.c\")(-42)(#{a:#{b:undef}}));",
        "//assocPath(\"a.b.c\", -42, #{a:undef});",
        "//assocPath(\"a.b.c\")(-42, undef);",
        "assocPath(\"[0][0][0]\")(-42, undef /*#{}*/); // should (((-42,),),)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {props} from \"system://functional\"",
        "{}",
        "const o = #{a:1, b:2, c:3, d:4};",
        "$log(props([@a,@c,@b])(o)); // creates an array",
        "$log(props((@a,@d,@b))(o)); // creates a tuple",
        "$log(props(@a,@c,@d)(o)); // multiple retval",
        "$log(props(@a,(@b,[@c,@d]))(o)); // custom retval shape item x, (x, [x,x,]) "
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {assoc} from \"system://functional\"",
        "{}",
        "// assoc makes a shallow copy of the source and replaced the given property with the given value",
        "// either creates a record or a tuple",
        "const a = \"prop_a\";",
        "$log(assoc(@alma, 42, #{a, alma:56, korte:11}));",
        "$log(assoc(@alma)(42)(#{a, alma:56, korte:11}));",
        "$log(assoc(0, 42, [10,20,30]));",
        "$log(assoc(2, 42, (10,20))); // extends tuple"
      ]
    },
