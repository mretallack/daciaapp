    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Iter.unfold - Fibonacci",
        "",
        "Iter.unfold returns an iterable generated by a function. The function is invoked with a state and it should return the next value and next state.<br>",
        "The returned iterator is an infinite iterator. So the next example only takes the first 10 of the infinite Fibonacci sequence"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "...Iter.unfold(st=> {st[0], (st[1], st[0]+st[1])},(1,2)).take(10)"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Playground to test async backtrace functionality"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "async f(l) {",
        "    l(\"f started\");",
        "    await Chrono.delay(0);",
        "    l(\"f finished\");",
        "    42;",
        "}",
        "async g(l,next, ...arg) {",
        "    const r = await next(l,...arg);",
        "    l(\"delegate finished\");",
        "    r",
        "}",
        "{}",
        "const r = await g($log, g, g,f);",
        "$log(\"Finished\", r)"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## async do {}"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "`async do {}` helps executing async stuff within sync function or in case result is not to be immediatelly awaited",
        "",
        "`async do {`_..._`}` is the same as `(async () => {`_..._`})()` (called async IIFE)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "f(log) {",
        "    async do {",
        "        log(\"async start\");",
        "        await Chrono.delay(10);",
        "        console.log(\"wait finished\");",
        "    };",
        "    log(\"f finished\");",
        "}",
        "{}",
        "f($log);"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "The result of `async do` is a promise"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "    let r1 = async do {",
        "        $log(\"async start 1\");",
        "        await Chrono.delay(2);",
        "        $log(\"wait 1 finished\");",
        "        1",
        "    };",
        "    let r2 = async do {",
        "        $log(\"async start\");",
        "        await Chrono.delay(1);",
        "        $log(\"wait 2 finished\");",
        "        42",
        "    };",
        "    await .all(r1,r2);"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Sample filter with func prog",
        "",
        "TODO: finish example"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "    sample_filter() {",
        "      const FalseFunc = F.constant(false);",
        "      function filterTests(tests, suiteFilter) {",
        "        let suiteFilters = seq( suiteFilter ?? ()).flatMap( f => {",
        "            if (f?.regexp) {",
        "                let regexp = new re.Regexp(f.regexp);",
        "                return item => regexp.exec(string(item.id));",
        "            }",
        "            if (let k = f?.kind) return item => isKindMatch(k, item, include);",
        "            if (let t = f?.tag) return item => isSuiteTag(t, item.suite.tags);",
        "            if (typeof(f) == @string || typeof(f) == @id) return item => string.eq(item.id, f);",
        "            return;",
        "        }).toArray();",
        "",
        "        return filter(tests, (item) => any(suiteFilters, call(?, item))).toArray();",
        "      }",
        "      let res = filterTests(AllTests, [{regexp: \"Func\"}]);",
        "      let x=5;",
        "    }",
        ""
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## lazy object",
        "",
        "`lazy` and `lazyAsync` helps in lazy value calculation. You pass a function to calculate a value and they create a lazy object that delays the calculation of the value to the first access (on-demand). Furthermore `lazyAsync` could handle async initialization. Once the promise settles the resolved value is stored and the function is released."
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {lazy, failure} from \"system://core\"",
        "{}",
        "const l = lazy(()=> { $log(\"init called\"); 42 });",
        "$log(\"before\");",
        "let v = l.value;",
        "$log(\"after\", v);",
        "v"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "If the init function fails (returns a failure) and you pass the `@retry` option the init function is retried on subsequent property access.",
        "",
        "The `value` property is observable when the initialization might need time such as this case or in case of `lazyAsync`."
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {lazy, failure} from \"system://core\"",
        "import {onChange, observeValue} from \"core://observe\"",
        "{}",
        "let fail = true;",
        "const l = lazy( @retry ,     ()=> { $log(\"init called\"); fail ? failure(\"init failed\") : 42 });",
        "$log(\"before\");",
        "let v = l.value;",
        "let s = observeValue(() => l.value, @noInit).subscribe(v => $log(\"value changed to \", v));",
        "$log(\"after init\", v);",
        "$log('allowing init to succeed');",
        "fail = false;",
        "v = l.value;",
        "$log(\"after non-failing init\", v);"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "`lazyAsync` can be used to await async init. The `value` property is observable"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {lazyAsync, failure} from \"system://core\"",
        "import {onChange, observeValue} from \"core://observe\"",
        "{}",
        "const l = lazyAsync( async ()=> { $log(\"init called\"); await Chrono.delay(5s); $log(\"init finished\"); 42});",
        "$log(`before, init ${l.initialized}, ongoing ${l.initializing}`);",
        "let v = l.value;",
        "let s = observeValue(() => l.value, @noInit).subscribe(v => $log(\"value changed to \", v));",
        "$log(`pending value : ${l.value}, init ${l.initialized}, ongoing ${l.initializing}`);",
        "await Chrono.delay(6s);",
        "$log(`after, value : ${l.value}, init ${l.initialized}, ongoing ${l.initializing}`);",
        "l",
        ""
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Observable"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {observeValue, onChange, Observable, fromGen, fromIter, CancellationTokenSource} from \"core://observe\"",
        "{}",
        "const cts = CancellationTokenSource($cancellation);",
        "observeValue(_=>Chrono.now).subscribe(t=>console.log(t/1000), cts.token);",
        "await Chrono.delay(5s, $cancellation);",
        "$log(\"Cancelled\");",
        "cts.cancel();",
        "await Chrono.delay(2s, $cancellation)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {Observable, fromGen, fromIter, CancellationTokenSource} from \"core://observe\"",
        "*iterWlog(i) {",
        "    for(const v in i) {",
        "        console.log('yielding:',v);",
        "        yield v;",
        "    }",
        "    console.log(\"finish\");",
        "}",
        "{}",
        "const cts = new CancellationTokenSource;",
        "//fromIter([1,2,3]).subscribe(v => {console.log(v); if (v>=2) cts.cancel()}, cts.token);",
        "fromIter(iterWlog([1,2,3])).subscribe(v => {console.log(v); if (v>=2) cts.cancel()}, cts.token)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {Observable, fromGen, fromIter, CancellationTokenSource} from \"core://observe\"",
        "import {connectable} from \"system://core.observe\"",
        "{}",
        "connectable(fromIter(iterWlog([10,20,30]))).subscribe(v=>$log(`Got {v}`));",
        "undef"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "let disp = connectable(fromIter(iterWlog([10,20,30])));",
        "let s2;",
        "let s1=disp.subscribe(v=>{",
        "    $log(`1 Got ${v}`); ",
        "    if (v==10) {",
        "        s2=disp.subscribe(v=>",
