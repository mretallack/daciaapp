    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {observeValue} from \"core://observe\"",
        "{}",
        "odict d { prop=0};",
        "function setAndLog(v) {",
        "    d.prop = v;",
        "    $log(\"Set to\", v);",
        "}",
        "let s = observeValue(() => d.prop, @noInit).subscribe(v => $log(\"value changed to \", v));",
        "$log(\"started\");",
        "setAndLog(1);",
        "s.withUpdateSuppressed(setAndLog, 2);",
        "setAndLog(3);"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "### asyncQueue",
        "",
        "asyncQueue converts an observable to an async iterator. "
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {asyncQueue, Observable} from \"core://observe\"",
        "object obs {",
        "    listener;",
        "}",
        "const obsIf = Observable((listener) => {obs.listener = listener; ()=>{obs.listener=undef}});",
        "{}",
        "for await (const v in asyncQueue(obsIf))",
        "    $log(\"yielded value\", v);",
        "$log(\"Finished\");"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "Triggering the observable should yield the iterator"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "{}",
        "obs.listener.next(1);obs.listener.next(2);",
        "await Chrono.delay(0);",
        "console.log(\"post delay\");",
        "obs.listener.next(10);"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "finishes observable"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "obs.listener.error(\"loszar\")",
        "//obs.listener.complete(\"loszar\")"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {filter, firstValueFrom, observeValue, timeout} from \"core://observe\"",
        "import {id} from \"system://core\"",
        "object data {",
        "    connected=false;",
        "}",
        "{",
        "}",
        "const res = ?? await (observeValue(()=>data.connected) |> filter(id, ^) |> timeout(2s, ^) |> firstValueFrom(^));",
        "$log(res && \"conntected\");"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "{}",
        "data.connected=true"
      ]
    }
  ]
}