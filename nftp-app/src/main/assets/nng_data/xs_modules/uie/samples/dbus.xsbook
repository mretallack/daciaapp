      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Exporting objects",
        "",
        "",
        "Any object may be exported via `sessionbus.registerObject(<path>, obj)`. For better introspection capabilities the class object should provide a static `interface` field describing the signatures. This can be a sequence when, describing multiple interfaces. "
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import { makeInterface, makeInterfaceT } from \"dbus/dbusCommunicator.xs\"",
        "",
        "class AddressSearch {",
        "    ",
        "    Start(what) {",
        "        console.log(\"Searching for: \", what);",
        "        // todo: would register a new object with communicator at this point, tracking the search",
        "        return \"/com/nng/navi/addressSearch/tasks/newSearch1\"",
        "    }",
        "    static interface = makeInterfaceT [{",
        "    name: \"com.nng.navi.addressSearch\",",
        "    methods : {",
        "        Start: (\"what:string\", \"string\"), ",
        "        Stop: (\"string, string\", \"uint\"),",
        "    }",
        "    }];",
        "}",
        "",
        "AddressSearch search;",
        "",
        "sessionbus.registerObject(\"/com/nng/navi/addressSearch\", search); // consider: export is a good name as well",
        "",
        "console.log(\"Address search interface: \", AddressSearch.interface);"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {makeInterface} from \"dbus/dbusCommunicator.xs\"",
        "",
        "class FooBar {",
        "    static interface;   ",
        "    Foo(what) { return what; }",
        "    Bar(text, limit) { return [\"foo\", \"bar\"]; }",
        "    Bar2(text, limit) { return [\"foo2\", \"bar2\"]; }",
        "}",
        "",
        "FooBar.interface = makeInterface({",
        "    name: \"com.nng.navi.Foo\",",
        "    methods : {",
        "        Foo: (\"what:string, how:string\", \"string\"),",
        "    }",
        "}, {",
        "    name: \"com.nng.navi.Bar\",",
        "    methods : {",
        "        Bar: (\"text:string, limit:int\", \"string\"), // string[]",
        "        Bar2: (\"string,int\", \"string\"), // string[]",
        "    }",
        "});",
        "",
        "class Baz {",
        "    static interface;",
        "    Baz(text, limit) { return \"baz\", 1; }",
        "}",
        "",
        "Baz.interface = makeInterface({",
        "    name: \"com.nng.navi.Baz\",",
        "    methods : {",
        "        Baz: (\"string,int\", \"string,int\"),",
        "    }",
        "});",
        "",
        "class BazBaz {",
        "    static interface;",
        "    BazBaz(text) { return \"baz\"; }",
        "    Alma = \"Starking\";",
        "    ReadP = 42;",
        "    WriteP = -42;",
        "    RWP = 111;",
        "}",
        "",
        "BazBaz.interface = makeInterface({",
        "    name: \"com.nng.navi.BazBaz\",",
        "    methods : {",
        "        BazBaz: (\"string\", \"string\"),",
        "    },",
        "    properties: {",
        "        Alma: \"string\",",
        "        ReadP: (\"uint\", @read),",
        "        WriteP: (\"int\", @write),",
        "        RWP: (\"uint\", @readwrite),",
        "    }",
        "});",
        "",
        "",
        "FooBar foobar;",
        "Baz baz;",
        "BazBaz bazbaz;",
        "sessionbus.registerObject(\"/com/nng/navi/foobar\", foobar);",
        "sessionbus.registerObject(\"/com/nng/navi/foobar/baz\", baz);",
        "sessionbus.registerObject(\"/com/nng/navi/foobar/bazbaz\", bazbaz);"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import { transformSignature } from \"system://dbus\"",
        "{}",
        "transformSignature(\"macska: {string  : (int64, int)}, alma:uint16, complex:(int16[][], string)[]\")"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {dict, odict, record} from \"system://core.types\"",
        "import {objOf, pipe} from \"system://functional\";",
        "dict Alma {",
        "    fromEntries(i) { Iter.mapApply(i, (k,v) => (\"_\" + k + \"_\", v + 1000)) |> record.fromEntries(^); }",
        "}",
        "const Alma2 = objOf(@fromEntries, i => i.mapApply((k,v)=> {\"_\" + k + \"_\", v + 1000}).toRecord() );",
        "const Alma3 = objOf(@fromEntries, pipe( Iter.mapApply(?, (k,v) => (\"_\" + k + \"_\", v + 1000)), record.fromEntries(?)) );",
        "",
        "Alma2 a { x=5; y=6}",
        "a;"
      ]
    }
  ]
}