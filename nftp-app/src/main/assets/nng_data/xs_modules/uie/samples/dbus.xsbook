    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "# Dbus scripting examples"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "Sending hello message with **dbus writer** from C++"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "/// env:default!",
        "import { DbusConnection} from \"dbus/dbus.xs\"",
        "",
        "DbusConnection sessionbus; // todo: should we keep this ctor: { additionalName = \"com.nng.navi\" }?",
        "{}",
        "",
        "await sessionbus.connect();",
        "console.log(\"connection ready, unique name: \", sessionbus.name);",
        "await sessionbus.messageBus.RequestName(\"com.nng.navi\");"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Send notifications with org.freedesktop.Notifications"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "class NotificationsWrapper {",
        "    proxy;",
        "    s1;",
        "    s2;",
        "    async init() {",
        "        this.proxy = await sessionbus.getProxyObject(\"org.freedesktop.Notifications\", '/org/freedesktop/Notifications');",
        "        this.s1 = this.proxy.NotificationClosed.subscribe((s, args) => { console.log(\"NotificationClosed signal received: \", args); });",
        "        this.s2 = this.proxy.ActionInvoked.subscribe((s, args) => { console.log(\"ActionInvoked signal received: \", args); });",
        "    }",
        "    Notify(title, details=\"\") {",
        "        this.proxy.Notify(\"TestApplication\", 0, \"\", title, details, [\"ok\", \"Ok\", \"cancel\", \"Cancel\"], {}, 10000);",
        "    }",
        "}",
        "",
        "{}",
        "",
        "// const s = sessionbus.onSignal().subscribe((signal, args)=> { console.warn(\"Action: \", signal, args) });",
        "",
        "// Start daemon on WSL Ubuntu: /usr/lib/notification-daemon/notification-daemon &",
        "const noti = new NotificationsWrapper();",
        "await noti.init();",
        "const nReply = await noti.Notify(\"This is a title\", \"Detailed comment\");",
        "console.log(`Message ID: ${nReply}`);",
        "await Chrono.delay(10s); // wait for signal"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Using the Notifications system",
        "There is a sample implementation of a Notifications system (similar, but much simpler than in Android OS), using node-next library.",
        "Source can be found here: https://bitbucket.nng.com/projects/UE/repos/dbus-test/browse/src/dbus-infotainment.js",
        "",
        "If you start this program and connect it to the same DBUS instance, it will register with the `com.nng.infotainment` well known bus name.",
        "",
        "It will expose the `/com/nng/ift/notifications` object with the following interface:",
        "- `Show(title:string, text:string):uint` Show a new notification with the given title and text. Will return with the unique id of the notification",
        "- `Cancel(id:uint):bool` Cancel a notification given by it's id. Returns true if the noti could be canceled",
        "- `List():struct(uint, string, string)[]` List the currently active notifications, grouping properties in a struct: (id, title, text)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "{}",
        "const xml = await sessionbus.Introspect(\"com.nng.infotainment\", '/com/nng/ift/notifications');",
        "console.log(xml);"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import { ObjectWrapper, makeInterface } from \"dbus/dbusCommunicator.xs\"",
        "",
        "dict d{ noti; s;};",
        "{}",
        "",
        "// Creating a simple object wrapper for a remote object, with a well known interface",
        "// this is the old implementation using ObjectWrapper",
        "class Notifications extends ObjectWrapper {",
        "    constructor(comm) {",
        "        super(comm, {",
        "            destination: \"com.nng.infotainment\",",
        "            interface: 'com.nng.ift.Notifications',",
        "            path: '/com/nng/ift/notifications'",
        "        })",
        "    }",
        "    ",
        "    List() { this.call(\"List\", \"\") }",
        "    Show(title, text) { this.call(\"Show\", \"ss\", title, text) }",
        "    Cancel(id) { this.call(\"Cancel\", \"u\", id) }",
        "}",
        "",
        "// with createProxyObject",
        "const noti = sessionbus.createProxyObject(\"com.nng.infotainment\", '/com/nng/ift/notifications', makeInterface({",
        "    name: 'com.nng.ift.Notifications',",
        "    methods: {",
        "        List:   (\"\",                          \"(id:uint, title:string, text:string)[]\"),",
        "        Show:   (\"title:string, text:string\", \"id:uint\"),   ",
        "        Cancel: (\"id:uint\",                   \"success:bool\"), ",
        "    },",
        "    transforms: { // using transforms we could add prcessing for method prop and signal results",
        "        List(res) {",
        "            // map result into readable format",
        "        }",
        "    }",
        "}));",
        "console.log(await noti.List());",
        "",
        "// with getProxyObject",
        "// d.s = sessionbus.onSignal({member: \"PropertiesChanged\"}).subscribe((s, arg) => {console.warn(s, arg)});",
        "d.noti = await sessionbus.getProxyObject(\"com.nng.infotainment\", '/com/nng/ift/notifications');",
        "d.s = d.noti.PropertiesChanged.subscribe((s, arg) => {",
        "    console.warn(s);",
        "    const iface, changed, invalidated = ...arg;",
        "    for (let prop in changed)",
        "        console.log(`Property \"${prop[0]}\" changed to ${prop[1]}`);",
        "});",
        "await d.noti.List();"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "Example of showing a new notification "
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "await d.noti.Show(\"Incoming call\", \"Bela is calling...\")"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "Example of canceling notifications"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "await d.noti.Cancel(1)"
      ]
    },
    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "Property access: getting the first notification (readonly prop)"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "// NOTE: cell execution autimatically awaits if result is a promise",
        "d.noti.First"
      ]
    },
    {
      "kind": "markup",
