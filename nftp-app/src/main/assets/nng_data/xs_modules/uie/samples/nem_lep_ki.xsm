#!/usr/bin/env -S xs -X
import {SIGINT} from "system://signal"; 
{}
SIGINT.default=application.exit(?);
let c=0;
const resp=["Nem lepek ki!", "Ne is probalkozz!", "Mondom, hogy nem!", "Na jo, megis kilepek"];
let sub = SIGINT.subscribe(s => {
    console.log(resp[min(c,resp.length-1)]);
    ++c;
    if (c < resp.length)
        SIGINT.preventDefault();
});
console.log('Nyomhatod a ^C-t, nem fog kilepni 20s-ig');
await Chrono.delay(20s)
