    {
      "kind": "markup",
      "language": "markdown",
      "source": [
        "## Sampla async construction",
        "",
        "Althought constructors can't be async a static create function could be used instead.<br>",
        "This static function can be inherited, by using `this` in new expression it will create instance of the derived class."
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "class A {",
        "    constructor() { console.log(\"A\");}",
        "    static async create() {",
        "        await 1;",
        "        new this();",
        "    }",
        "}",
        "class B extends A {",
        "    constructor() { super(); console.log(\"B\");}",
        "}",
        "{}",
        "await B.create()"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {DisposableStack} from \"system://core.types\"",
        "import {objOf} from \"core://functional\"",
        "import {dispose} from \"system://core\"",
        "{}",
        "DisposableStack s;",
        "s.adopt(42, +> console.log(\"adopted\", ^));",
        "s.use(object {ku= 42; [Symbol.dispose](...v) { console.log(\"Disposed\", this, ...v);}});",
        "s.defer(console.log(\"deferred\",?));",
        "dispose(s);"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {DisposableStack,AsyncDisposableStack} from \"system://core.types\"",
        "import {objOf, pipe} from \"core://functional\"",
        "import {dispose, asyncDispose, failure, getFailObject} from \"system://core\"",
        "{}",
        "AsyncDisposableStack s;",
        "s.adopt(42, arg => { console.log(\"adopted\", arg)} );",
        "s.use({ku:42, async [Symbol.asyncDispose](arg) { console.log(\"Disposed\", this, arg)}});",
        "s.use({tya:42, async [Symbol.asyncDispose](arg) { console.log(\"Disposed\", this, arg)}});",
        "s.defer(console.log(\"deferred\",?));",
        "const v = await s[Symbol.asyncDispose]();",
        "v"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "{}",
        "failure(\"ba\")"
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {defineProperty} from \"system://core\"",
        "const mySym = Symbol(\"proba symbol\");",
        "const mySym2 = Symbol(\"proba symbol\");",
        "decorator @defineProperty(name, conf) {",
        "    @register(o => defineProperty(o?.prototype ?? o, name, conf))",
        "} ",
        "@defineProperty(mySym, #{value: 1024})",
        "@defineProperty(mySym2, #{get: function() {this.kutya()} })",
        "class Proba",
        "{",
        "    kutya() { 1}",
        "    prop = 42;",
        "}",
        "{}",
        "const o = new Proba;",
        "$log(Proba.prototype, o[Symbol.prototype]);",
        "o.prop, o[mySym], o[mySym2]"
      ]
    },
    {
