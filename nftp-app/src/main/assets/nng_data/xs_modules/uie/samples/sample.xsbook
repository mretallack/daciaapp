    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import { isStringTemplateObject} from \"system://core\"",
        "",
        "f(str, ...args) {",
        "    console.log(\"is string template\", isStringTemplateObject(str));",
        "    console.log(str,...args);",
