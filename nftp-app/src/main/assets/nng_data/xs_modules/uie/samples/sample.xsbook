    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {getIterator, isIterDone} from \"system://core\"",
        "",
        "*wrap(g) {",
        "    g = getIterator(g);",
        "",
        "    let last = g.next();",
        "    if (isIterDone(last))",
        "        return l;",
        "    for(let n in g) {",
        "        last.next = n;",
        "        yield last;",
        "        last = n;",
        "    }",
        "    yield last;",
        "}",
        "",
        "{}",
        "for(const x in wrap([{a:10}, {b:20}, {c:30}]))",
        "    console.log(x);",
        ""
      ]
    },
    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "import {runAsyncGenerator, hasProp} from \"system://core\"",
        "*sync() {",
        "    console.log(1);   yield 2;",
        "    console.log(2);   yield 3;",
        "    console.log(3);   yield 3;",
        "    console.log(4);",
        "    return 42;",
        "}",
        "*notsync() {",
        "    console.log(1);    yield 2;",
        "    console.log(2);    yield Promise.resolve(1);",
        "    console.log(3);    yield 3;",
        "    console.log(4);    yield 3;",
        "    console.log(5);",
        "    return 42;",
        "}",
        "",
        "let res = runAsyncGenerator(notsync()); // try sync",
        "if (res && hasProp(res, @then)) {",
        "    console.log(\"awaiting async...\");",
        "    res= await res;",
        "}",
        "console.log(\"result\", res);"
      ]
    },
