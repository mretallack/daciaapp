        "const subs = broadcastReceiver(IntentFilterType(\"nng.uie.message.type\")).",
        "                  subscribe(intent=>console.log(\"intent received\", intent.action, intent.getStringExtra(\"KUTYA\"), intent));",
        "{}",
        "subs // is a BroadcastReceiver and a Subcription"
      ]
