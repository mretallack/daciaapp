        "import { javaClass } from \"android://reflect\"?",
        "",
        "// Address will map to this class when not on Android platform",
        "class XsAddress {",
        "    id;           ///< @type {string}",
        "    addressName;  ///< @type {string}",
        "    addressDesc;  ///< @type {string}",
        "    distance;     ///< @type {double}",
        "    latitude;     ///< @type {double}",
        "    longitude;    ///< @type {double}",
        "} ",
        "",
        "export const Address = javaClass?.(\"com.saicmotor.adapterservice.bean.Address\") ?? XsAddress;",
        "{}",
        "const ad = {id:\"alma\", addressName:\"korte\"};",
        "const a = Address.fromEntries(ad);",
        "a"
      ]
