    {
      "kind": "code",
      "language": "xsmixed",
      "source": [
        "/// env:yellow",
        "import {IntentType as Intent, startActivity} from \"android://intents\"",
        "import {scan} from \"android://barcode\"",
        "{}",
        "let res = await scan({qrOnly: true, prompt: \"miert fordulsz el Please scan QR code on headunit\", lock:true});",
        "console.log(res);",
        "return;",
        "/*ComponentInfo{com.nng.yellowbox/com.journeyapps.barcodescanner.CaptureActivity}*/",
        "// SCAN_FORMATS = comma separated list of formats: QR_CODE_MODE, DATA_MATRIX_MODE",
        "// CAMERA_ID, BARCODE_IMAGE_ENABLED=false",
        "Intent zx{ action=\"com.google.zxing.client.android.SCAN\"; flagClearTop=true;",
        "           component=\"com.nng.yellowbox/com.journeyapps.barcodescanner.CaptureActivity\";",
        "           //component = \"com.google.zxing.integration.android/.\";",
        "           // com.journeyapps.barcodescanner/.ScanContract",
        "           BEEP_ENABLED=false;",
        "           SHOW_MISSING_CAMERA_PERMISSION_DIALOG=true;",
        "           SCAN_ORIENTATION_LOCKED= true;",
        "           PROMPT_MESSAGE=\"Scan QR code on HU\";",
        "           }",
        "startActivity(zx)"
      ]
    },
