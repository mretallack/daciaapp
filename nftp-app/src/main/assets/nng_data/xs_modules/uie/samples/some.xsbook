        "$log(w.size);",
        "const o = {x:11};",
        "$log(w.emplace(o, k=>k.x+31));",
        "$log(w?.[o]);",
        "$log(w?.[{x:12}]);",
        "$log(w.emplace(o, k=>k.x+11, (v,k)=>v+k.x));",
        "$log(w?.[o]);",
        "$log(w.emplace(o, k=>k.x+11, console.log(\"Called\",?)));",
        "$log(o,w[o]);",
        "$log(w.emplace(o, undef, ()=>Symbol.NoProperty));",
        "$log(w[o]??\"removed as it should have been\");",
        "$log(w.emplace(o, ()=>Symbol.NoProperty));",
        "$log(w[o]??\"still has not inserted\");",
