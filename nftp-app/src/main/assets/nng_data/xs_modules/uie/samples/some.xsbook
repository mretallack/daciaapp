        "import {ArrayBuffer, DataView, DataReader, Uint8Array, DataWriter} from \"system://core.types\"",
        "import {and, shr,shl} from \"system://math\"",
        "import {typeof} from \"system://core\"",
        "",
        "odict conn { reqId = 0};",
        "put32(b, off, data) {",
        "    for(let i =0; i<4; ++i) {",
        "        b[off++] = data;",
        "        data = shr(data,8);",
        "    }",
        "    off;",
        "}",
        "send(id, ...args) {",
        "    let b = DataWriter(256);",
        "    b.u32(0).u16(id).u16(++conn.reqId);",
        "    let off = 8;",
        "    for(const v in args) {",
        "        typeof(v) == @string ? b.string(v) : b.u32(v)",
        "    }",
        "    b.u32At(0, b.pos /*=len*/); // TODO: u32At is ugly, myabe could be somethog b.writeAt(0, @u32, len )",
        "    return DataReader.view(b, 0, b.pos)",
        "}",
        "{}",
        "let r = send(10, \"alma\", 42, \"korte\", 23);",
        "//console.log(r.vli(), r.vli(), r.vli(), r.vli());",
        "r.order = @be;",
        "console.log(r.u32(@le)); // override @be with @le",
        "r.order = @le;",
        "console.log(/*r.u32(@be), */ r.u16(), r.u16(), r.string(2), r.string(), r.u32(), r.string(), r.u32() );",
        "r.pos;",
        "",
        "let w = DataWriter();",
        "w.u32(2999);",
        "console.log(w.pos, w[0], w[1], w[2],w[3], w.u32At(0))"
      ]
    },
