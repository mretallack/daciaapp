      "language": "xsmixed",
      "source": [
        "import {pipe} from \"core://functional\"",
        "prop(name, obj) {",
        "    obj[name]",
        "}",
        "props(fields, obj) {",
        "    Iter.map(fields, prop(?, obj));",
        "}",
        "pick(fields, obj) {",
        "    Iter.zip(fields, props(fields, obj)).toRecord();",
        "} ",
        "hasAnyExt(extensions) { // return a func checking if name has any extension",
        "    name => Iter.any(extensions, name.endsWith(?))",
        "}",
        "{}",
        "const files = [#{name:\"alma.gif\"}];",
        "$log(...",
        "   Iter.filter(files, pipe(prop(@name,?), hasAnyExt([\".jpeg\",\".gif\",\".bmp\"]))));",
        "pick([@a, @c], #{a:10, b:20, c:42})"
      ]
    }
