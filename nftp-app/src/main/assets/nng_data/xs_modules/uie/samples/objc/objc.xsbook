        "        this.pasteBtn = showPasteAt(x,-1);",
        "        ctrl.installCapture();",
        "        this.ctrl = ctrl;",
        "    }",
        "    finish() {",
        "        this.pasteBtn?.removeFromSuperview();",
        "        this.pasteBtn = undef;",
        "        this.ctrl = undef;",
        "    }",
        "}",
        "{}",
        "setExternalPasteHandler(iosPasteHandler);"
