        "import {setExternalPasteHandler} from \"uie/components/inputComponent.ui\"",
        "object iosPasteHandler {",
        "    pasteBtn;",
        "    ctrl;",
        "    showAt(x,y, ctrl, w) {",
        "        this.finish();",
        "        if (!objc.class.UIPasteboard.generalPasteboard.hasStrings)",
