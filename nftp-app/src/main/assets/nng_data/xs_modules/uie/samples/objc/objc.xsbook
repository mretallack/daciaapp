        "import {iosKeyboardManager} from \"uie/input/iosSoftInput.xs\"",
        "import {uicolor} from \"uie/ios/UiKit.xs\"",
        "const UIPasteControlConfiguration = objc.class.UIPasteControlConfiguration;",
        "const UIPasteControl = objc.class.UIPasteControl;",
        "const CGRect = objc.struct(\"CGRect\");",
        "enum UIPasteControlDisplayMode {",
        "    IconAndLabel = 0,",
        "    IconOnly =1,",
        "    LabelOnly = 2",
        "}",
        "showPasteAt(x,y) {",
        "    const conf = new UIPasteControlConfiguration;",
        "    conf.baseForegroundColor = uicolor(#000);",
        "    conf.baseBackgroundColor = uicolor(#00e0e0);",
        "    conf.displayMode = UIPasteControlDisplayMode.LabelOnly;",
        "    const paste = UIPasteControl.initWithConfiguration(conf);",
        "    const nw = screen.root.nativeWindow;",
        "    const inp = iosKeyboardManager.activeConnection?.iosInputView;",
        "    paste.frame = CGRect(#{x, y, w:100, h:50});",
        "    paste.target = inp;",
        "    inp.addSubview(paste);",
        "    paste;",
        "}",
        ""
