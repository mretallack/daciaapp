class FormData{
    title = "";
    subTitle = "";
    inputList;
    beforeValidateFields;
    mainActionText;
    mainAction;
    altActionText;
    altAction;
    mainActionEnable;
    altActionEnable;
    actionsVisible;
}

export class FormHandler {
    @disposeNull formUser;
    @disposeNull fields;
    formPages;

    constructor( fields, formPages ) {
        this.fields = fields;
        this.formPages = formPages 
    }

    getFormFields( page ) {
        if ( ! ??this.formPages[ page ] ) {
            console.log("[form handler] No such formfield in the handler");
            return;
        }

        const inputList = map( field => {
            this.fields[ field ]
        }, this.formPages[ page ].inputList );

        const thiz = this;

        return FormData{
            title = thiz.formPages[ page ].title;
            subTitle = thiz.formPages[ page ].subTitle ?? "";
            inputList = inputList;
            mainActionText = thiz.formPages[ page ].mainActionText ?? "";
             mainAction = ( controller ) => {
                inputFocus.setInputFocus(undef, screen.root); // close keyboard
                ??thiz.formPages[ page ].beforeValidateFields();
                if ( !thiz.validateFields( inputList ) )
                    return;
                ??thiz.formPages[page].mainAction( controller );
            };
            altActionText = thiz.formPages[ page ].altActionText ?? "";
            altAction = ( controller ) => {
                if (??thiz.formPages[page].altAction)
                    thiz.formPages[page].altAction( controller );
                else 
                    app.back();
            };
            mainActionEnable := thiz.formPages[ page ].mainActionEnable ?? undef;
            altActionEnable := thiz.formPages[ page ].altActionEnable ?? undef;
            actionsVisible := thiz.formPages[ page ].actionsVisible ?? undef;
        }
    }

    fillAddressToSend( formAddress ) {
        let address = {
            addressType: formAddress.addressType,
            country: formAddress.country,
            postalCode: formAddress.postalCode,
            city: formAddress.city,
            lines: [ formAddress.address1, formAddress.address2 ],
            firstName: formAddress.firstName,
            lastName: formAddress.lastName,
        };
        if(formAddress?.region){
            address.region = formAddress.region;
        }
        return address;
    }

    erasePasswordFields() {
        for ( let k, field in entries( this.fields )) {
            if ( field.inputType == @password ) {
                field.value = "";
                field.errorText = "";
                field.valid = true;
            }
        }
    }

    clearCheckoutFields(){
        this.fields.acceptProviderAssumption.value = false;
        this.fields.acceptProviderAssumption.errorText = "";
        this.fields.acceptProviderAssumption.valid = true;        
        
        this.fields.readAndAcceptTerms.value = false;
        this.fields.readAndAcceptTerms.errorText = "";
        this.fields.readAndAcceptTerms.valid = true;

        this.fields.rightOfWithdrawal.value = false;
        this.fields.rightOfWithdrawal.errorText = "";
        this.fields.rightOfWithdrawal.valid = true;
    }

    validateFields( fieldList ) {
        let valid = true;
        for (const field in fieldList) {
            field.valid = true;
            if ( field.type != @submenu ) {
                valid = field.validate() && valid;
            }
        }

        // Note: all validate could run in this order
        let validateConfirmPasswordField = ??fieldList.find( e => e==formHandler.fields.confirmPassword || e==formHandler.fields.changePasswordConfirmPassword );
        if ( ??validateConfirmPasswordField )
            valid = this.validateConfirmPassword( validateConfirmPasswordField ) && valid;
    
        return valid;
    }

    validateConfirmPassword( passwordField ) {
        if ( this.fields.password.value != passwordField.value) {
            this.fields.password.valid = false;
            passwordField.valid = false;
            this.fields.password.errorText= i18n`The passwords do not match.`;
            passwordField.errorText= i18n`The passwords do not match.`;
            return false;
        }
        return true;
    }

    reset() {
         map( field => {
            ??field.reset();
        }, values( this.fields ));
    }
}

@dispose
export CurrentUser currentUser;
export FormUser formUser;
export FormCar formCar;

@dispose
export const formHandler = new FormHandler( formFields, formPages );

const useMocks = SysConfig.get("yellowBox", "useMocks", false );

export isAccessTokenValid(token) {
    return token && ( useMocks || !JWT.checkExpired(JWT.decodePayload(token)) )
}

export goToSignIn(){
    currentUser.signOut();
    app.next(@UserSignIn);
}

export list addressTypes ["DEFAULT", "INVOICE", "SHIPPING"];

class Field {
    type  = @text;
    required = false;
    enable = true;
    value = "";
    title = "";
    valid;
    errorText;
    validator;

    __customValidator() {
        return this.validator ? this.validator( weak(this) ) : true;
    };

    __resetValidation() {
        this.valid = undef;
        this.errorText = undef;
    }

    __validateRequired() {
        // Required for checkbox means that it is mandatory to check
        // TODO: checkbox error text should be different.
        if ( this.required && !this.value ){
            this.valid = false;
            this.errorText = i18n`This field is required.`;
            return false;
        }
        return true
    }

    reset() {
        this.__resetValidation();
        this.value = "";
    }

    validate() {
        const reqVal = this.__validateRequired();
        return reqVal ? this.__customValidator() : false;
    }
}

export class InputField extends Field {
    inputType = @standard;
    bottomRightText = "";
    bottomRightFunction;
    maxLength;
    }

export class SelectCountry extends Field {
    type = @dropCountry;
    items;
}

export class CheckBoxField extends Field {
    text = ""; // string or tuple for rich formatter (formatting has to happen at text because the format string is translated and can change when lang changes )
    value = false;
    boxOnRelease;
    linkOnrelease;

    reset() {
        this.__resetValidation();
        this.value = false;
    }
}

showLoadingMsgBox(text) {
    let noti = new Messagebox;
    noti.addLine(text).setOverlay()
    .addIcon({ name: "loading.svg", class: ("loadingProgress", "animated") })
    .show();
    return noti;
}

export showLogoutMsgBox() {
    let noti = new Messagebox;
    noti.addLine(i18n`If you log out you won’t be able to use this application.`).setOverlay()
    .addIcon("user.svg")
    .addButton( new Button({text:i18n`Logout`, action: _ => { currentUser.signOut(); } }))
    .addButton( new Button({text:i18n`Cancel`, style: @info}))
    .setId(@logoutMsgbox)
    .show();
    return noti;
}

const needToBackAfterRegistration = ["Redeem"];

// -------- user registration --------------
export startRegistration( params ) {
    formUser.clear();
    formHandler.reset();
    getBanner(@userReg).hide();
    formUser.fromState = params?.from;
    app.next( @UserReg );
}

registrationNext() {
    fillBilling( formUser.formInfo.billingAndAddressAreSame );
    app.next( @UserRegAddressEdit );
}

nextToSignIn(){
    let method = @set;
    if ( formUser?.fromState && needToBackAfterRegistration.includes( formUser.fromState.dname) )
        method = @next;
    app.selectScreenById( @UserSignIn, method );
}

export async tryToRegisterUser(){
    const loadingMsgBox = showLoadingMsgBox(i18n`Registering...`);
    const reg = await registerUsr();
    loadingMsgBox.hide();

    trackEvent("register", {status: reg?.success});

    if (reg?.success) {
        formHandler.erasePasswordFields();
        getBanner(@userReg).hide();
        nextToSignIn();
        getBanner(@signIn).show( i18n`Please verify your email address to complete your registration!`, {level: @warning});
        return true;
    } else {
        getBanner(@userReg).show( reg.data.message ?? reg.message, {level: @error});
        return false, reg.data.message ?? reg.message;
    }
}

export async registerUsr() {
    const device = headUnit.device ?? headUnit.lastConnectedDevice;
    //const detailedAddresses = [formHandler.fillAddressToSend( formUser.address ), formHandler.fillAddressToSend( formUser.billing )];
    let copyAddress = formHandler.fillAddressToSend( formUser.billing );
    copyAddress.addressType = "DEFAULT";
    copyAddress.firstName = formUser.address.firstName;
    copyAddress.lastName = formUser.address.lastName;

    const detailedAddresses = [copyAddress, formHandler.fillAddressToSend( formUser.billing )];

    const userData = {
        detailedAddresses,
        subscribeToNewsletter: formUser.other.newsLetterSubscribed,
    };

    const userCredentials = {
        name: formUser.infos.username,
        email: formUser.infos.email,
        password: formHandler.fields.password.value,
        channel: config.device.channel,    
    };
    return registerUser(device, userData, userCredentials, config.device.channel);
}

// -------------- Sign in -----------------
async tryToSignIn(){
    const loadingmsgBox = showLoadingMsgBox(i18n`Signing In...`);
    const userCredentials = { email: formUser.infos.email, password: formHandler.fields.passwordSignIn.value, channel: config.device.channel };
    const ret = await signInUsr(userCredentials);
    const usedEmail = formUser.infos.email;
    const device = headUnit.device ?? headUnit.lastConnectedDevice;
    loadingmsgBox.hide();
    if (ret?.success) {
        getBanner(@signIn).hide();
    } else {
        const emailNotConfirmed = ret?.data?.errorCategory == "USER" && ret?.data?.errorType == "EMAIL_IS_NOT_CONFIRMED";
        const callback = emailNotConfirmed ? ()=>resendRegistrationEmail( device, usedEmail, config.device.channel ) : undef;
        getBanner(@signIn).show( ret.message, { level: @error, onRelease: callback })
    }

    if (ret?.success) setUserId(userCredentials.email);
    trackEvent("signIn", {status: ret?.success});
    if (ret?.success) {
        formHandler.erasePasswordFields();
        formHandler.reset();
        if ( app.contentController.length > 1 )
            if (formUser?.fromState && needToBackAfterRegistration.includes( formUser.fromState.dname))
                app.backTo( formUser.fromState );
            else 
                app.back();
        else 
            app.selectScreenById( @Shop, @set );
    }
};

export event signInEvent;

export async signInUsr(userCredentials) {
    const ret = await loginUser(userCredentials);
    if (ret?.success) {
        userCredentials.email = ret.data.email;
        currentUser.credentials = userCredentials;
        yellowStorage.setLastUsedUsername( userCredentials.email );
        currentUser.token = ret.data.userToken;
        packageList.fillPackageList();
        yellowStorage.setUserAccessToken(currentUser.token);
        await currentUser.updateInfos();
        signInEvent.trigger( currentUser );
    }
    return ret;
}

// ----------------- Forgot password -------------------
async tryForgotPwd(){
    const loadingmsgBox = showLoadingMsgBox(i18n`Processing...`);
    const ret = await forgotPwd();
    loadingmsgBox.hide();
    trackEvent("forgotPassword",  {status: ret?.success});
    if ( ret?.success ) {
        app.back();
        let bannerScreen = @signIn;
        if (app.currentScreen.id == @ChangePassword)
            bannerScreen = @changePassword;
        getBanner(bannerScreen).show(i18n`Email sent.`, {level: @success});
    } else {
        if ( !currentUser.tokenIsValidFromResponse(ret) ){
            goToSignIn();
            return;
        }
        getBanner(@forgotPassword).show( ret.message, {level: @error} );
    }
}

export async forgotPwd () {
    const ret = await forgotUserPassword( formUser.infos.email, config.device.channel );
    formHandler.erasePasswordFields();
    return ret;
}

// ----------------- Change password ------------------------
async tryToChangePwd( ctrl ){
    const loadingmsgBox = showLoadingMsgBox(i18n`Changing password...`);
    let result = await changePwd();
    loadingmsgBox.hide();
    trackEvent("changePassword", {status: result?.success});
    if ( result?.success ) {
        formHandler.erasePasswordFields();
        getBanner(@changePassword).show(i18n`Password changed.`, {level: @success});
    } else {
        if ( !currentUser.tokenIsValidFromResponse(result) ){
            goToSignIn();
            return;
        }
        getBanner(@changePassword).show( result.message , {level: @error});
    }  
}

export async changePwd() {
    let result = await changeUserPassword( currentUser.token, formHandler.fields.oldPassword.value, formHandler.fields.password.value );
    if ( result?.success ) {
        currentUser.credentials.password = formHandler.fields.password.value;
    }
    return result;
}

// ---------------- Edit user data -------------------
export async saveUserData(){
    // detect changes
    let changed = false;
    let fields = formHandler.formPages.editUser.inputList;
    for ( let key in fields ) {
        if ( formHandler.fields[ key ]?.type == @submenu || formHandler.fields[ key ]?.type == @checkbox )
            continue;
        let current = currentUser.infos[ key ] ?? currentUser.address[ key ];
        let modified = formUser.infos[ key ] ?? formUser.address[ key ];
        if ( current != modified ) {
            changed = true;
            break;
        }
    }

    if( !changed )
        changed = currentUser.other.newsLetterSubscribed != formUser.other.newsLetterSubscribed;

    // Update user and news letter subscription
    if ( changed ){
        const loadingmsgBox = showLoadingMsgBox(i18n`Updating...`);
        //let addresses = [ formHandler.fillAddressToSend( formUser.address ), formHandler.fillAddressToSend( formUser.billing ) ];
        let copyAddress = formHandler.fillAddressToSend( formUser.billing );
        copyAddress.addressType = "DEFAULT";
        copyAddress.firstName = formUser.address.firstName;
        copyAddress.lastName = formUser.address.lastName;

        let addresses = [ copyAddress, formHandler.fillAddressToSend( formUser.billing ) ];
        let userData = { detailedAddresses: addresses, subscribeToNewsletter: formUser.other.newsLetterSubscribed };
        const newsLetterOp = formUser.other.newsLetterSubscribed ? @subscribe : @unsubscribe;
        const res = await Promise.all([
            updateUser( currentUser.token, userData, currentUser.credentials ),
            newsLetterOperation( currentUser.token, newsLetterOp )
        ]);
        if ( res[0].success ) {
            if ( res[1].success )
                currentUser.other.newsLetterSubscribed = formUser.other.newsLetterSubscribed;
            await currentUser.updateInfos();
            loadingmsgBox.hide();
            app.back();
            formUser.clear();
        }else {
            loadingmsgBox.hide();
            if ( !currentUser.tokenIsValidFromResponse(res) ){
                goToSignIn();
                return;
            }
            getBanner(@userEdit).show( res[0].message, {level: @error});
        }
    }
    else
        app.back();
}

// ---------------- Edit billing address ------------------
export async editBillingAddAddress() {
    await updateBilling();
}

export async updateBilling() {
    const loadingMsgBox = showLoadingMsgBox(i18n`Updating...`);
    const detailedAddresses = [formHandler.fillAddressToSend( formUser.address ), formHandler.fillAddressToSend( formUser.billing )];
    let userData = { detailedAddresses };
    let res = await updateUser( currentUser.token, userData, currentUser.credentials );
    if ( res.success ) {
        await currentUser.updateInfos();
        loadingMsgBox.hide();
        app.back();
    }else {
        loadingMsgBox.hide();
        if ( !currentUser.tokenIsValidFromResponse(res) ){
            goToSignIn();
            return;
        }
        getBanner(@userEdit).show( res.message, {level: @error});
    }  
}

export fillBilling( chkValue ) {
    if ( chkValue ) {
        // close keyboard when "Use the same address for billing" checked and every input fields are disabled
        inputFocus.setInputFocus(undef, screen.root);
        formUser.billing.firstName = formUser.address.firstName;
        formUser.billing.lastName = formUser.address.lastName;
        formUser.billing.country = formUser.address.country;
        formUser.billing.postalCode = formUser.address.postalCode;
        formUser.billing.city = formUser.address.city;
        formUser.billing.address1 = formUser.address.address1;
        formUser.billing.address2 = formUser.address.address2;
    }
}

// ---------------- VALIDATORS ----------------
export validateCountryField(field) {
    const valid = isValidCountry(field.value);
    field.valid = valid;
    field.errorText= i18n`This field is required.`;
    return valid;
}

validateAddressType(field) {
    const valid = addressTypes.indexOf(field.value) > -1;
    field.valid = valid;
    return valid;
}

const emailRegexp = Regexp("^[a-z0-9!#$%&'*+/=?^_`{|}~-]+(?:\.[a-z0-9!#$%&'*+/=?^_`{|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])$", "i");
validateEmail(field) { 
    field.valid = emailRegexp.test(field.value);
    if (!field.valid) {
        field.errorText = i18n`Invalid email address.`
    } 
    return field.valid
}

validateMinPasswordChar(field){
    field.valid = field.value.length >= 6;
    if (!field.valid) {
        field.errorText = i18n`The password must contain at least 6 characters.`
    } 
    return field.valid
}

// --------------------LAYOUT----------------------
export <fragment frOverlay class=fill, shown>
	<sprite class=fill, bg, fade/>
</fragment>

export <fragment frForm class=main, flexible, vertical flex=1
    onHide() {
        dispose(inputScroll);
    }
    onRelease() { inputFocus.releaseFocusInside(this);} 
>
    own {
        let vm = (??controller.current.formFields);
        let inputScroll = new InputFocusScroll(fragment.scrollable);
    }
    <group scrollable class=flexible, vertical, mainContentPadding, scrollable flex=1 valign=@top>
        <sprite class=bg, item, fill position=@absolute paddingBottom=15/>
        <banner banner=(getBanner(controller.state?.banner)) />
        <group class=flexible,vertical,form,formTitle >
            <text class=h2 text=(vm.title ?? "") visible=(??vm.title) />
            <text class=h2, secTitle text=(vm.subTitle ?? "") visible=(??vm.subTitle)/>
        </group>
        <sprite class=separator, form>
        <includeChildren />
        <lister model=(vm.inputList ?? []) param={controller}  template=tInputField 
            templateType() { 
                if ( item.type == @dropCountry )
                    return tDropCountry; 
                elsif ( item.type == @checkbox )
                    return tCheckBox;
                elsif ( item.type == @switch )
                    return tSwitch;
                elsif ( item.type == @submenu )
                    return tAction;
                else
                    return @default; 
                }
        />
            <includeChildren filter=".afterInput"/>
        <wheel />  
        <scroll />
    </group>
    <group class=flexible, vertical, mainContentPadding, extraLargePaddingY visible=(??vm.actionsVisible ?? true)>
        <sprite class=bg, topLine />
        <button class=footer,action,smallMarginY text=(vm.mainActionText ?? "") enable=(??vm.mainActionEnable ?? true) visible=(??vm.mainActionText) onRelease() { vm.mainAction( controller ) } />
        <button class=footer,secondary,smallMarginY text=(vm.altActionText ?? "") enable=(??vm.altActionEnable ?? true) visible=(??vm.altActionText) onRelease() { vm.altAction( controller ) } />
    </group>
</fragment>

export <fragment frSignInOrRegister class=flexible, vertical visible:={!isAccessTokenValid( currentUser.token ) && (controller.current?.signInVisible ?? true)}>
    <group class=flexible, vertical, mainContentPadding, extraLargePaddingY>
		<sprite class=bg, topLine />
		<button class=footer,action,smallMarginY text=i18n`Sign In` onRelease() { currentUser.copyToForm(); app.next(@UserSignIn) }  />
		<button class=footer,secondary,smallMarginY text=i18n`Register` onRelease() { startRegistration( {from: controller.current}) } />
    </group>
</fragment>

export <fragment frForgotPassword class=main,flexible,vertical extends=frForm>
    <group class=flexible, vertical, dataInfo>
        <group class=flexible,horizontal>
            <text class=paragraph text=i18n`Please enter your email address and we'll send you instructions on how to reset your password`/>
        </group>
    </group>
</fragment>

export <template tInputField class=field layout=@flex>
    <formInput
        value<=>item.value
        type=( item.inputType )
        valid=( item.valid != false )
        title=(fmt("{0:s}{1:s}",item.title, (item.required ? "*" : "")))
        errorText=( item.errorText ?? "" )
        maxLength=( item.maxLength ?? 100 )
        bottomRightText=( item.bottomRightText ?? "" )
        bottomRightFunction=( item.bottomRightFunction ?? undef )
        checkBoxText=( item.checkBoxText ?? "" )
        checkBoxOnRelease=( item.checkBoxOnRelease ?? undef )
        checkBoxValue<=>( item.checkBoxValue ?? false ),( newVal ){ item.checkBoxValue = newVal }
        enable=( item.enable ?? true )
        actionHint=((index < owner.model.findLastIndex(i => i?.inputType)) ? @next : @done)
    />
</template>

export <template tCheckBox class=field layout=@flex>
    <checkbox class=( @formCheckBox, (item.valid != undef && !item.valid ) ? @invalid : "" ) checked<=>item.value onRelease() { ??item.boxOnRelease( this.checked ) }>
        <group class=flexible,vertical >
            <text t1 class=paragraph, smallpaddingX, mainMarginY text=( fmtTuple(item.text)) onRelease=(item?.linkOnrelease) visible=( item.text )/>
            <text class=error text=( item.errorText ) visible=( !item.valid && item.errorText )/>
        </group>
    </checkbox>
</template>

<template tDropMenuCountry boxAlign=@stretch>
    <text class=( param.hasValue ? @normalColor: @emptyColor, @paragraph ) text=(translateCountry(item)) wordWrap=1 maxW=200 />
</template>

<template tDropDownCountryItem extends=tDropDownItem>
    <text class=detail fontSize=16 maxW=200 text=(translateCountry(item)) />
    <spacer flex=1 />
</template>

export <template tDropCountry class=field layout=@flex>
    own {
        let title = (fmt("{0:s}{1:s}",item.title, (item.required ? "*" : "")));
    }
    <group class=flexible, vertical>
        <dropMenu title=(title) dir=@down value<=>item.value items=(item.items) enable=( item.enable ?? true )
            templateItem=tDropDownCountryItem
            templateMenu=tDropMenuCountry
        />
        <group class=flexible,vertical visible=( !item.valid && item.errorText ) >
            <text class=error text=( item.errorText ) />
        </group>
    </group>
</template>
