    // Redeem code
    redeemCode = InputField { title = i18n`Enter your code here`; value<=>formRedeem.code; required= true };
};

 openEmbeddedUrl( url, store, data ) {
    if ( event.target.textInfoAtPos(event)?.style?.underline )
        openUrl( url ?? config.links.default );
    else if ( ??store && ??data )
        invert( formUser[store][ data ] );
}

