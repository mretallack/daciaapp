export TextStyle LinkStyle { underline=true }

class User {
    other = odict{
        newsLetterSubscribed = true;
    };
    infos = odict{
        username = "";
        email = "";
        language = "";
    };
    address = odict{
        addressType = "DEFAULT";
        country = "";
        postalCode = "";
        city = "";
        address1 = "";
        address2 = "";
        firstName = "";
        lastName = "";
    };
    billing = odict{
        addressType = "INVOICE";
        country = "";
        postalCode = "";
        city = "";
        address1 = "";
        address2 = "";
        firstName = "";
        lastName = "";
    };

    clear( skipMail = false ) {
        this.address = createBlankAddress("DEFAULT");
        this.billing = createBlankAddress("INVOICE");
        this.infos.username = "";
        if ( !skipMail )
            this.infos.email = "";
        this.infos.language = "";
        this.other.newsLetterSubscribed = true;
    }
}

export const createBlankAddress = function( type ) {
    odict {
        addressType = type;
        country = "";
        postalCode = "";
        city = "";
        address1 = "";
        address2 = "";
        firstName = "";
        lastName = "" 
    }
};

const compareAddresses = function( addr1, addr2 ) {
    return
        addr1.country == addr2.country && addr1.postalCode == addr2.postalCode &&
        addr1.city == addr2.city && addr1.city == addr2.city &&
        addr1.address1 == addr2.address1 && addr1.address2 == addr2.address2
};

class CurrentUser extends User {
    credentials = {};
    token;
    infoStatus = @none;     // @none, @loading, @ready
    get infosReady() {
        this.infoStatus == @ready;
    }
    @dispose #netChangeSubs;
    salesforceKey;
    @dispose #pollSalesforceTask;

    constructor() {
        super();
        this.infos.email = yellowStorage.getLastUser(); // NOTE: using getLastUser so, persisted data can be reused, this can be changed...
        this.token = this.#getToken();
        // user case: There is a valid token but there is no internet at start
        this.#netChangeSubs = networkStatus.subscribe((status) => {
            if (status?.internet && this.infoStatus==@none && isAccessTokenValid(this.token)) 
                this.updateInfos();
        });
    }

    #getToken() {
        const token = yellowStorage.getUserAccessToken();
        if (!isAccessTokenValid(token)) 
            return;
        this.token = token;
        this.salesforceKey = yellowStorage.getUserSalesforceKey(this.infos.email);
        if (token)
            this.updateInfos();
        return token;
    }

    #fillAddress( detailedAddress, type=@address ) {
        this[type].country = detailedAddress.country ?? "";
        this[type].postalCode = detailedAddress.postalCode ?? "";
        this[type].city = detailedAddress.city ?? "";
        this[type].address1 = detailedAddress.lines[0] ?? "";
        this[type].address2 = detailedAddress.lines[1] ?? "";
        this[type].firstName = detailedAddress.firstName ?? "";
        this[type].lastName = detailedAddress.lastName ?? "";
    }

    #isValidAddress(address) {
        // todo: validate other fields
        if (!isValidCountry(address.country)) return false;
        if (addressTypes.indexOf(address.addressType) < 0) return false;
        if (address.city.length == 0) return false;
        return true;
    }

    hasValidAddress(type) {
        this.#isValidAddress( this.billing );
    }

    setPushNotificationEnabled(enabled) {
        if (!this.token) return;
        const op = enabled ? @enablePushNotification : @disablePushNotification;
        pushNotificationOperation(this.token, op, config.device.channel);
        if (enabled) {
            this.#startPollSalesforceKey();
        } else {
            this.#pollSalesforceTask?.cancel();
        }
    }

    async #pollSalesforceKey(delay, ctoken) {
        await Chrono.delay(delay, ctoken);
        while (!ctoken.canceled) {
            const result = await pollSalesforceKey(this.token, ctoken);
            const retryAfter = result?.retryAfter ?? 2s;
            const salesforceKey = result?.data?.salesforceKey ?? "";
            if (result.success && salesforceKey.length > 5) {
                this.salesforceKey = salesforceKey;
                yellowStorage.setUserSalesforceKey(this.infos.email, this.salesforceKey);
                mcPropertyHandler.sync();
                return;
            }
            await Chrono.delay(retryAfter, ctoken);
        }
    }

    #startPollSalesforceKey(delay = 5s){
        if (this.salesforceKey) return;
        this.#pollSalesforceTask?.cancel();
        this.#pollSalesforceTask = new CancellationTokenSource();
        this.#pollSalesforceKey(delay, this.#pollSalesforceTask.token);
    }

    async updateInfos() {
        this.infoStatus = @loading;
        const result = await Promise.all([
            getUser( this.token ), 
            newsLetterOperation( this.token, @isSubscribed ),
        ]);
        if ( result[0]?.success ) {
            // Enable Push Notification on server side too
            const isEnabled = yellowStorage.pushNotiEnabled;
            if (isEnabled) {
                this.setPushNotificationEnabled(isEnabled);
            }

            // update user infos
            const userInfos = result[0].data;
            for (let addr in userInfos.userData.detailedAddresses) {
                if ( addr.addressType != "DEFAULT" && addr.addressType != "INVOICE" )
                    continue;

                const type = addr.addressType == "DEFAULT" ? @address : @billing;
                this.#fillAddress( addr, type );
            }
            this.infos.username = userInfos.name;
            this.infos.email = userInfos.email;
            setUserId(userInfos.email);

            // newsletter subscription
            if ( result[1]?.success ) {
                this.other.newsLetterSubscribed = result[1].data.subscribed ?? false;
            }
            this.infoStatus = @ready;
        }
        else {
            this.infoStatus = @none;
            let noti = new Messagebox;
            noti.addLine(i18n`Unable to connect to the server.`)
            .setOverlay()
            .addIcon( "Network.svg" )
            .addButton( new Button({text:i18n`Ok` }) );
            noti.show();
        }
        return result;
    }

    signOut( tempUser = formUser ) {
        trackEvent("signOut");
        setUserId(undef); // subsequent events won't be tracked with this userId
        this.clear( true );
        this.#pollSalesforceTask?.cancel();
        this.salesforceKey = undef;
        this.infoStatus = @none;
        this.credentials = undef;
        this.token = undef;
        yellowStorage.setUserAccessToken(undef);
        yellowStorage.setUserSalesforceKey(this.infos.email, undef);
        packageList.reset();
    }

    // Makes a copy of the current user so it can be modified in forms
    copyToForm( tempUser = formUser ) {
        tempUser.infos.username = this.infos.username;
        tempUser.infos.email = this.infos.email;
        tempUser.infos.language = this.infos.language;

        tempUser.address = createBlankAddress("DEFAULT");
        tempUser.billing = createBlankAddress("INVOICE");

        // Copy if there's already a saved address
        tempUser.address.country = this.address.country;
        tempUser.address.postalCode = this.address.postalCode;
        tempUser.address.city = this.address.city;
        tempUser.address.address1 = this.address.address1 ?? "";
        tempUser.address.address2 = this.address.address2 ?? "";
        tempUser.address.firstName = this.address.firstName;
        tempUser.address.lastName = this.address.lastName;

        tempUser.billing.country = this.billing.country;
        tempUser.billing.postalCode = this.billing.postalCode;
        tempUser.billing.city = this.billing.city;
        tempUser.billing.address1 = this.billing.address1 ?? "";
        tempUser.billing.address2 = this.billing.address2 ?? "";
        tempUser.billing.firstName = this.billing.firstName;
        tempUser.billing.lastName = this.billing.lastName;

        tempUser.other.newsLetterSubscribed =  this.other.newsLetterSubscribed;
        // Filled address
        if ( this.address.address1 )
            tempUser.checkAddressEquality();
        else
            tempUser.formInfo.billingAndAddressAreSame = false;

        return tempUser;
    }
    tokenIsValidFromResponse( response ){
		if( !response?.success && [ "INVALID_USER_TOKEN", "EXPIRED_USER_TOKEN" ].includes(response.data.errorType ?? undef)){
			return false
		}
		return true
	}
}

class FormUser extends User {
    formInfo = odict {
        billingAndAddressAreSame = false;
        eulaAccepted = false;
        providerAssumptionAccepted = false; 
        readAndAcceptTermsAccepted = false;
        rightOfWithdrawalAccepted = false
    };
    fromState;
    checkAddressEquality() {
        this.formInfo.billingAndAddressAreSame = compareAddresses( this.address, this.billing );
    }

    clear( skipMail = false ) {
        super.clear( skipMail );
        this.formInfo.billingAndAddressAreSame = false;
        this.formInfo.eulaAccepted = false;
        this.formInfo.providerAssumptionAccepted = false;
        this.formInfo.readAndAcceptTermsAccepted = false;
        this.formInfo.rightOfWithdrawalAccepted = false;
        this.fromState = undef;
    }
}

class FormCar {
    #oldName;
    name = "";
    swid = "";
    lastConnected;
    freeSpace;
    mapType = "";

    fill( device ) {
        this.swid = device.swid;
        this.name = device.name;
        this.#oldName = device.name;
        this.lastConnected = device.lastConnected;
        this.mapType = device.hasOSM ? i18n`NNG maps` : (device.hasOSM == undef ? i18n`unknown` : i18n`HERE maps`);
        this.freeSpace = headUnit.device.swid == this.swid ? headUnit?.freeDiskSize : undef;
    }

    saveCarSettings() {
        if ( this.name != "" && this.name != this.#oldName )
            renameDevice( this.swid, this.name );
        refreshKnownDevices();
    }

    clear() {
        this.name = "";
        this.swid = "";
        this.lastConnected = undef;
        this.freeSpace = undef;
        this.mapType = "";
    }
}

