import radio from "uie/components/radio.ui"
import tTag from "./components/tag.ui"
import { Toast } from "~/src/components/toasts.xs"
import { Messagebox, Button } from "./components/messageboxes.xs";
import {} from "./details.nss.xs"
import { reduce } from "system://functional"
import { keys } from "system://core"
import alert from "./components/alert.ui"
import {formatSize, splitFileAndExt, contentGrouping, eliminateHtmlTags} from "./utils/util.xs"
import {tDropDownItem} from "~/src/components/dropMenu.ui"
import { i18n, translate } from "system://i18n"
import {fmt} from "fmt/formatProvider.xs"
