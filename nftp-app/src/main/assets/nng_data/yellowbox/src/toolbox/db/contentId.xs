    (0xA618AB04,(decodeCommon, "JUNCTIONVIEWDB")),
    (0x20091120,(decodeCommon, "TMCDECRYPTKEYS")),
    (0x87B4F528,(decodeCommon, "JUNCTIONVIEWNGDB")),
    (0x76634B51,(decodeCommon, "CURVEALERTDB")),
    (0x20130826,(decodeCommon, "SPEEDCAMERADB")),    // (ALERTPOINT)
    (0x594c67ed,(decodeGFS, "GFS")),
];

/// Expects block to be an Uint32Array, block can be longer than 4k
/// The block will be decoded/encoded in place
crypt(block, opts) {
    // The code is constructed from c++ code in contentIdReader project
    // this explains the naming of variables and the code style
    const BLOCK_SIZE = 4096;
    const inputLength = block.byteLength;
    
    let bDecode = opts?.decode;
    let bDecode2 = false;
    let bFirst = true;
	let nID = 0;
    let nCID = 0;
	let nDataRead = BLOCK_SIZE;
    
    for (let i=0;;i++) { 
		let nOffset=i % 1024;
		if ((i + 1)*BLOCK_SIZE > inputLength)
		{
			nDataRead = inputLength % BLOCK_SIZE;
		}

		if (bFirst) 
		{
			if (!bDecode)
			{
				nCID = block[3];
				//std::cout << "ContentID used at encoding: " << nCID << std::endl;
			}
			bFirst = false;													
		} 
		else 
		{
			nID = nCID + nOffset;
		}

        const size = (nDataRead + 3) / 4;
		if (bDecode2) {
			for (let j = 0; j < size; j++)
				block[j] = xor(block[j] + nID,  xorTable[(j + nOffset) % 1024]);
		} 
		else {
			for (let j = 0; j < size; j++)
				block[j] = xor(block[j] , xorTable[(j + nOffset) % 1024]) - nID;
		}

		if (bDecode) 
		{	
			nCID = block[3];
			
			bDecode = false;
			bDecode2 = true;
		}

		block = block.subarray(block.buffer, size); // set to the next block

		if (nDataRead != BLOCK_SIZE)
			break;
	} 
}

