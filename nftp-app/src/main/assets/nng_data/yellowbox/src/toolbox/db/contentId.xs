import {xor} from "system://math"
import {Uint32Array, Uint8Array, Uint16Array, DataView, DataReader, Map} from "system://core.types"
import { open } from "system://fs"
import * as Iter from "system://itertools";
import re from "system://regexp"
import {toLowerCase} from "system://string.normalize"

export async decodeContentIdFile(filePath) {
    const f = await open(filePath);
    const buf = Uint8Array(4096);
    const numRead = await f.read(buf);
	numRead && decodeContentId(buf.subarray(0,numRead));
}

export decodeContentId(buf) {
	if (buf.byteLength < 16)
		return undef;
    const headerView = DataReader.view(buf);
	let magicWord = headerView.u32At(0);
	let t = readers?.[magicWord];
    const block = Uint32Array.view(buf, 0, buf.byteLength/4*4);
	if (!t) {
    	crypt(block, { decode : true } );
		magicWord = headerView.u32At(0);
		t = readers?.[magicWord];
	}
	t && t[0](headerView, t)
}

const commentSep = "\\n\\"; // not a new line but blackslash + n two times
const ccCodeInInfo = re`\\n[\\n\n]+([^|]*)`;
const infoCCVerAndPkg = re`\\n[\\n\n]+([^|]*)(?:\|([^|]*)(?:\|[^|]*\|([^|]*))?)?`;
export countryCodeOf(info) {
	ccCodeInInfo.exec(info.comment)?.[1];
}

export commentToRegionVerPkg(info) {
	const m = infoCCVerAndPkg.exec(info.comment);
	m ? (: m[1], m?.[2], m?.[3] ) : (:undef, undef, undef)
}
export isOSMContent(info, name) {
	info.comment.startsWithNoCase('[osm') ||
		( info.comment.startsWith('[nng') && name.toLowerCase().indexOf("_osm.") >= 0)
}

// providerIcon string from the content comment
export getProviderByComment( comment ) {
	const startPos = comment.indexOf("[");
	const endPos = comment.indexOf("]");
	if ( startPos >=0 && endPos > startPos )
		return comment.substr( startPos+1, endPos-startPos-1).toLowerCase();
	// GPS and More has no [provider] prefix only thing to check whether the comment contains "GPS and More"
	if (comment.indexOf("GPS and More")>=0)
		return "gps_and_more"
}

decodeSetData(r) {
    const info = {
        timeStamp: r.u32At(8),
        contentVersion: r.u16At(129 * 4)
    };
    const cidCount = min(r.u32At(12),100); // safety measure if something is going amiss
    if (cidCount == 1)
        info.contentId = r.u32At(16);
    else 
        info.contentIds = Iter.range(cidCount).map(idx => r.u32At(16+4*idx) ?? undef ).toArray();
    
    // headerOffset in bytes
    let headerOffset = 4 * 4 + 4 * cidCount;
    const headerCommentSize = r.u16At(headerOffset); // comment size in wchars
    
    headerOffset += headerCommentSize * 2 + 2 * 2;
    // simple got to get content comment string
    // todo: this should be repeated for all cids
    const segmentOffset = r.u32At(headerOffset, true);
    const commentSize = r.u16At(segmentOffset + 4 * 4, true);
    info.comment = r.utf16(segmentOffset + 4 * 4 + 2 * 2, commentSize);
    
    return info;
}
decodeCommon(r) {
	const info = {
        timeStamp: r.u32At(8),
        contentVersion: r.u16At(4),
		contentId: r.u32At(12),
	};
	const commentSize = r.u16At( 16, true);
    info.comment = r.utf16(20, commentSize);
	return info;
}

decodeUnknown() {

}
decodeApp() {}
decodeGFS() {}
decodeZip() { // similar to common, but block[3] is count, block[4] is contentId
	const info = {
        timeStamp: r.u32At(8),
        contentVersion: r.u16At(4),
		contentId: r.u32At(16),
	};
	return info;
}
// TODO: refince common info reader
Map readers [
	(0x45474E4E,(decodeApp, "APPLICATION")),  // NNGE
    (0x00544553,(decodeSetData, "FILESET")),
    (0x5a474E4E,(decodeZip, "ZIP")),         // NNGZ
    (0x05307713,(decodeCommon, "STATICTMC")),
    (0x8D621E3A,(decodeCommon, "HISTSPEED")),
