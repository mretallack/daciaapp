<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#333333">

        <Button android:id="@+id/tabProbe" style="@style/TabButton" android:text="Probe" />
        <Button android:id="@+id/tabDevice" style="@style/TabButton" android:text="Device" />
        <Button android:id="@+id/tabExplorer" style="@style/TabButton" android:text="Explorer" />
        <Button android:id="@+id/tabLog" style="@style/TabButton" android:text="Log" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
