<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/editHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Emulator IP"
            android:inputType="text"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not connected"
        android:textSize="14sp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnNngProbe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Probe NNG SDK Symbols"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnNngEngine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start NNG Engine"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnConnectEmulator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NNG TCP Connect"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnQueryDisk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NNG Query DiskInfo"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/txtNngResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="11sp" />
    </ScrollView>
</LinearLayout>
